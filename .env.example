# ─────────────────────────────────────────────────────────
#  Bonzo Concierge — Environment Variables
#  Copy this file to .env and fill in your own values.
#  Never commit .env — it is already in .gitignore.
# ─────────────────────────────────────────────────────────

# ── Hedera Account ────────────────────────────────────────
# The treasury/operator account that signs all on-chain transactions.
# Format: shard.realm.account  (e.g. 0.0.12345)
# Get a free testnet account at: https://portal.hedera.com
HEDERA_ACCOUNT_ID=0.0.YOUR_ACCOUNT_ID

# ECDSA private key for the account above.
# Must be the raw DER-encoded hex string, NOT an ED25519 key.
# Starts with 302e… (DER) or simply the 32-byte hex after the prefix.
# Never share this key; it controls all agent funds.
HEDERA_PRIVATE_KEY=your_ecdsa_private_key_hex_here

# Network to connect to: "testnet" or "mainnet"
# Leave as "testnet" for all demo scripts and local development.
HEDERA_NETWORK=testnet

# Hedera JSON-RPC relay endpoint (used by EVM-compatible tooling).
# The public HashIO endpoint requires no API key.
HEDERA_RPC_URL=https://testnet.hashio.io/api

# ── OpenAI ────────────────────────────────────────────────
# Powers the GPT-4o-mini intent router that dispatches tool calls.
# Required for the /api/chat route and all agentic reasoning.
# Get a key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your_openai_api_key_here

# ── ElevenLabs (optional) ─────────────────────────────────
# Enables text-to-speech voice output in the chat UI.
# If left blank, the app runs silently — TTS is gracefully disabled.
# Get a key at: https://elevenlabs.io (free tier available)
ELEVEN_LABS_KEY=your_elevenlabs_api_key_here
